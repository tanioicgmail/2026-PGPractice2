<Window x:Class="KURAOrderSystem.Views.BikkuraPonWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="びっくらポン！"
        Height="600" Width="800"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="#D00B0F19"
        ShowInTaskbar="False">
    
    <Window.Resources>
        <!-- Rotation animation for Sunburst (Win Screen) -->
        <Storyboard x:Key="RotateSunburst" RepeatBehavior="Forever">
            <DoubleAnimation Storyboard.TargetName="SunburstRotation"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:15"/>
        </Storyboard>

        <!-- Shake animation for capsule machine container -->
        <Storyboard x:Key="ShakeMachine">
            <!-- Lever rotation -->
            <DoubleAnimation Storyboard.TargetName="LeverRotation"
                             Storyboard.TargetProperty="Angle"
                             From="0" To="360" Duration="0:0:1.5" DecelerationRatio="0.3"/>
            <!-- Shake Container X -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ContainerTranslation"
                                           Storyboard.TargetProperty="X">
                <EasingDoubleKeyFrame KeyTime="0:0:0.2" Value="5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.4" Value="-5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.6" Value="5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.8" Value="-5"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.0" Value="3"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.2" Value="-3"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.4" Value="1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.6" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
            <!-- Shake Container Y -->
            <DoubleAnimationUsingKeyFrames Storyboard.TargetName="ContainerTranslation"
                                           Storyboard.TargetProperty="Y">
                <EasingDoubleKeyFrame KeyTime="0:0:0.1" Value="-4"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.3" Value="4"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.5" Value="-4"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.7" Value="4"/>
                <EasingDoubleKeyFrame KeyTime="0:0:0.9" Value="-2"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.1" Value="2"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.3" Value="-1"/>
                <EasingDoubleKeyFrame KeyTime="0:0:1.5" Value="0"/>
            </DoubleAnimationUsingKeyFrames>
        </Storyboard>

        <!-- Capsule drop animation -->
        <Storyboard x:Key="DropCapsule">
            <DoubleAnimation Storyboard.TargetName="CapsuleTranslation"
                             Storyboard.TargetProperty="Y"
                             From="-180" To="120" Duration="0:0:1.2">
                <DoubleAnimation.EasingFunction>
                    <BounceEase Bounces="3" Bounciness="2" EasingMode="EaseOut"/>
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="CapsuleTranslation"
                             Storyboard.TargetProperty="X"
                             From="0" To="10" Duration="0:0:1.2"/>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="MainGrid">
        <!-- Background elements for Atari/Win state (initially collapsed) -->
        <Grid x:Name="SunburstGrid" Visibility="Collapsed">
            <Path Data="M 400,300 L 0,0 L 100,0 Z M 400,300 L 200,0 L 300,0 Z M 400,300 L 400,0 L 500,0 Z M 400,300 L 600,0 L 700,0 Z M 400,300 L 800,0 L 800,100 Z M 400,300 L 800,200 L 800,300 Z M 400,300 L 800,400 L 800,500 Z M 400,300 L 800,600 L 700,600 Z M 400,300 L 600,600 L 500,600 Z M 400,300 L 400,600 L 300,600 Z M 400,300 L 200,600 L 100,600 Z M 400,300 L 0,600 L 0,500 Z M 400,300 L 0,400 L 0,300 Z M 400,300 L 0,200 L 0,100 Z"
                  Fill="#33F59E0B" Stretch="Fill">
                <Path.RenderTransform>
                    <RotateTransform x:Name="SunburstRotation" CenterX="400" CenterY="300"/>
                </Path.RenderTransform>
            </Path>
        </Grid>

        <!-- Main Game Stage -->
        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Width="600" Height="500">
            
            <!-- Game Title Banner -->
            <Border Background="{StaticResource PanelBrush}" CornerRadius="16" Height="60" VerticalAlignment="Top" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                <TextBlock Text="★ びっくらポン！ カプセルゲーム ★" Foreground="{StaticResource AccentGoldBrush}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>

            <!-- 1. The Gashapon Capsule Machine Graphic -->
            <Canvas x:Name="GashaponCanvas" Width="300" Height="400" Margin="150,70,150,30">
                <!-- Capsule container background -->
                <Border Width="180" Height="180" Canvas.Left="60" Canvas.Top="20" Background="#30FFFFFF" BorderBrush="#80FFFFFF" BorderThickness="4" CornerRadius="90">
                    <Border.RenderTransform>
                        <TranslateTransform x:Name="ContainerTranslation"/>
                    </Border.RenderTransform>
                    <Canvas>
                        <!-- Floating capsule circles inside the machine -->
                        <Ellipse Width="35" Height="35" Fill="#FF4D4D" Canvas.Left="30" Canvas.Top="50" Opacity="0.9"/>
                        <Ellipse Width="35" Height="35" Fill="#4D96FF" Canvas.Left="80" Canvas.Top="30" Opacity="0.9"/>
                        <Ellipse Width="35" Height="35" Fill="#6BCB77" Canvas.Left="110" Canvas.Top="80" Opacity="0.9"/>
                        <Ellipse Width="35" Height="35" Fill="#FFD93D" Canvas.Left="50" Canvas.Top="100" Opacity="0.9"/>
                        <Ellipse Width="35" Height="35" Fill="#FF6B6B" Canvas.Left="95" Canvas.Top="115" Opacity="0.9"/>
                        <Ellipse Width="35" Height="35" Fill="#F59E0B" Canvas.Left="60" Canvas.Top="60" Opacity="0.9"/>
                    </Canvas>
                </Border>

                <!-- Capsule machine body -->
                <Path Data="M 40,200 L 260,200 L 240,350 L 60,350 Z" Fill="#EF4444"/>
                
                <!-- Front Glass highlights -->
                <Path Data="M 60,20 A 90,90 0 0,1 240,20" Stroke="#40FFFFFF" StrokeThickness="6" Fill="Transparent"/>

                <!-- Capsule exit chute -->
                <Border Width="60" Height="60" Canvas.Left="120" Canvas.Top="290" CornerRadius="12" Background="#1E293B" BorderBrush="#EF4444" BorderThickness="3">
                    <Grid>
                        <!-- Internal flap -->
                        <Rectangle Width="40" Height="8" Fill="#94A3B8" VerticalAlignment="Bottom" Margin="0,0,0,10"/>
                    </Grid>
                </Border>

                <!-- Crank / Lever -->
                <Grid Canvas.Left="150" Canvas.Top="230" Width="60" Height="60">
                    <Grid.RenderTransform>
                        <RotateTransform x:Name="LeverRotation" CenterX="30" CenterY="30"/>
                    </Grid.RenderTransform>
                    <Ellipse Width="24" Height="24" Fill="#F59E0B" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Rectangle Width="50" Height="8" Fill="#F8FAFC" RadiusX="4" RadiusY="4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <!-- 2. The Dropped Capsule (Initially Hidden/Invisible) -->
                <Grid x:Name="DroppedCapsule" Canvas.Left="135" Canvas.Top="150" Width="40" Height="40" Visibility="Hidden">
                    <Grid.RenderTransform>
                        <TranslateTransform x:Name="CapsuleTranslation"/>
                    </Grid.RenderTransform>
                    <!-- Two tone capsule sphere -->
                    <Border Background="#3B82F6" CornerRadius="20,20,0,0" Height="20" VerticalAlignment="Top"/>
                    <Border Background="#F3F4F6" CornerRadius="0,0,20,20" Height="20" VerticalAlignment="Bottom"/>
                    <Border Height="4" Background="#111827" VerticalAlignment="Center"/>
                </Grid>
            </Canvas>

            <!-- 3. Result Screen Overlay (Fades In) -->
            <Border x:Name="ResultPanel" Grid.RowSpan="3" Background="#F01E293B" CornerRadius="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="2" Margin="30,80,30,20" Visibility="Collapsed">
                <Grid Margin="24">
                    <!-- WIN Layout -->
                    <StackPanel x:Name="WinPanel" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="★ あたり ★" Foreground="{StaticResource AccentGoldBrush}" FontSize="44" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10">
                            <TextBlock.Effect>
                                <DropShadowEffect Color="Yellow" BlurRadius="10" ShadowDepth="0"/>
                            </TextBlock.Effect>
                        </TextBlock>
                        
                        <TextBlock Text="景品をゲットしました！" Foreground="White" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,20"/>
                        
                        <!-- Prize Graphic Placeholder (Using clean vector representations) -->
                        <Border BorderBrush="{StaticResource AccentGoldBrush}" BorderThickness="3" CornerRadius="12" Background="#2E3A59" Width="220" Height="150" Padding="10" HorizontalAlignment="Center">
                            <Grid>
                                <!-- Toy Capsule Icon -->
                                <Ellipse Width="70" Height="70" Fill="{StaticResource AccentGoldBrush}" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,10,0,0"/>
                                <TextBlock Text="🎁" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,15,0,0"/>
                                
                                <TextBlock x:Name="PrizeNameText" Text="マグロストラップ" Foreground="White" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10" TextAlignment="Center" TextWrapping="Wrap"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <!-- LOSE Layout -->
                    <StackPanel x:Name="LosePanel" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed">
                        <TextBlock Text="はずれ..." Foreground="{StaticResource AccentRedBrush}" FontSize="40" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                        <TextBlock Text="残念！また5皿食べて挑戦しよう！" Foreground="{StaticResource TextMutedBrush}" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,30"/>
                        <TextBlock Text="😢" FontSize="72" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                    </StackPanel>

                    <!-- Close Button -->
                    <Button x:Name="CloseBtn" Content="注文画面に戻る" Style="{StaticResource KuraButtonStyle}" Width="200" HorizontalAlignment="Center" VerticalAlignment="Bottom" Click="CloseBtn_Click"/>
                </Grid>
            </Border>

            <!-- Initial Action Text overlay -->
            <TextBlock x:Name="IntroText" Text="カプセルが回るよ！" Foreground="White" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,320,0,0"/>
        </Grid>
    </Grid>
</Window>
