<Window x:Class="KURAOrderSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KURAOrderSystem"
        xmlns:vm="clr-namespace:KURAOrderSystem.ViewModels"
        xmlns:helpers="clr-namespace:KURAOrderSystem.Helpers"
        mc:Ignorable="d"
        Title="くら寿司風 テーブルオーダーシステム" 
        Height="720" Width="1180"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <helpers:EmptyToCollapsedConverter x:Key="EmptyToCollapsedConverter"/>
        <helpers:BoolToVisibleConverter x:Key="BoolToVisibleConverter"/>

        <!-- DataTemplate for Sushi Items Grid -->
        <DataTemplate x:Key="SushiItemTemplate">
            <Border Style="{StaticResource CardStyle}" Width="190" Height="220" Margin="8">
                <Grid Margin="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="85"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Top Tag (e.g. Popular/New) -->
                    <Border Background="{StaticResource AccentGoldBrush}" CornerRadius="4" HorizontalAlignment="Left" Padding="6,2" Visibility="{Binding Tag, Converter={StaticResource EmptyToCollapsedConverter}}">
                        <TextBlock Text="{Binding Tag}" Foreground="Black" FontSize="11" FontWeight="Bold"/>
                    </Border>

                    <!-- Vector Illustration of Sushi (Interactive & Responsive) -->
                    <ContentControl Grid.Row="1" Width="130" Height="80" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <ContentControl.Style>
                            <Style TargetType="ContentControl">
                                <!-- Default (Nigiri Tuna style) -->
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ContentControl">
                                            <Grid>
                                                <!-- Plate -->
                                                <Ellipse Width="100" Height="36" Fill="#E2E8F0" Stroke="#CBD5E1" StrokeThickness="2" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                                <Ellipse Width="80" Height="26" Fill="#F1F5F9" VerticalAlignment="Bottom" Margin="0,0,0,7"/>
                                                <!-- Rice -->
                                                <Border Width="50" Height="20" Background="White" CornerRadius="10" VerticalAlignment="Bottom" Margin="0,0,0,14">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.1"/>
                                                    </Border.Effect>
                                                </Border>
                                                <!-- Fish -->
                                                <Border Width="68" Height="14" Background="#E11D48" CornerRadius="6" VerticalAlignment="Bottom" Margin="0,0,0,22">
                                                    <Border.Effect>
                                                        <DropShadowEffect BlurRadius="4" ShadowDepth="2" Opacity="0.2"/>
                                                    </Border.Effect>
                                                </Border>
                                            </Grid>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                                <Style.Triggers>
                                    <!-- Salmon -->
                                    <DataTrigger Binding="{Binding Name}" Value="サーモン">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Grid>
                                                        <Ellipse Width="100" Height="36" Fill="#E2E8F0" Stroke="#CBD5E1" StrokeThickness="2" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                                        <Border Width="50" Height="20" Background="White" CornerRadius="10" VerticalAlignment="Bottom" Margin="0,0,0,14"/>
                                                        <Border Width="68" Height="14" Background="#F97316" CornerRadius="6" VerticalAlignment="Bottom" Margin="0,0,0,22">
                                                            <Grid>
                                                                <Path Data="M 12,0 L 5,14 M 24,0 L 17,14 M 36,0 L 29,14 M 48,0 L 41,14 M 60,0 L 53,14" Stroke="#FFE4D6" StrokeThickness="1.5" Opacity="0.8"/>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- Seared Cheese Salmon -->
                                    <DataTrigger Binding="{Binding Name}" Value="炙りチーズサーモン">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Grid>
                                                        <Ellipse Width="100" Height="36" Fill="#E2E8F0" Stroke="#CBD5E1" StrokeThickness="2" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                                        <Border Width="50" Height="20" Background="White" CornerRadius="10" VerticalAlignment="Bottom" Margin="0,0,0,14"/>
                                                        <!-- Seared Salmon -->
                                                        <Border Width="68" Height="14" Background="#EA580C" CornerRadius="6" VerticalAlignment="Bottom" Margin="0,0,0,22">
                                                            <Grid>
                                                                <Path Data="M 12,0 L 5,14 M 24,0 L 17,14 M 36,0 L 29,14 M 48,0 L 41,14" Stroke="#FCD34D" StrokeThickness="2" Opacity="0.9"/>
                                                                <!-- Cheese Drizzle -->
                                                                <Path Data="M 5,2 Q 34,10 63,2 M 15,12 Q 34,4 53,12" Stroke="#FBBF24" StrokeThickness="2"/>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- Tamago -->
                                    <DataTrigger Binding="{Binding Name}" Value="たまご焼き">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Grid>
                                                        <Ellipse Width="100" Height="36" Fill="#E2E8F0" Stroke="#CBD5E1" StrokeThickness="2" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                                        <Border Width="50" Height="18" Background="White" CornerRadius="9" VerticalAlignment="Bottom" Margin="0,0,0,12"/>
                                                        <!-- Yellow Egg -->
                                                        <Border Width="65" Height="18" Background="#FBBF24" CornerRadius="4" VerticalAlignment="Bottom" Margin="0,0,0,18"/>
                                                        <!-- Nori belt -->
                                                        <Border Width="14" Height="22" Background="#111827" HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- Shrimp Tempura -->
                                    <DataTrigger Binding="{Binding Name}" Value="えび天にぎり">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Grid>
                                                        <Ellipse Width="100" Height="36" Fill="#E2E8F0" Stroke="#CBD5E1" StrokeThickness="2" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                                        <Border Width="50" Height="18" Background="White" CornerRadius="9" VerticalAlignment="Bottom" Margin="0,0,0,12"/>
                                                        <!-- Tempura Batter Golden -->
                                                        <Border Width="70" Height="16" Background="#F59E0B" CornerRadius="8" VerticalAlignment="Bottom" Margin="0,0,0,20">
                                                            <Grid>
                                                                <Ellipse Width="6" Height="6" Fill="#D97706" Margin="10,2,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                                                <Ellipse Width="4" Height="4" Fill="#D97706" Margin="25,6,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                                                <Ellipse Width="5" Height="5" Fill="#D97706" Margin="45,3,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                                            </Grid>
                                                        </Border>
                                                        <!-- Shrimp Tail Red -->
                                                        <Path Data="M 60,25 L 82,38 L 76,20 Z" Fill="#EF4444" VerticalAlignment="Bottom" Margin="0,0,5,15" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- Gunkan items (Negitoro, Salad, Corn, Ikura) -->
                                    <DataTrigger Binding="{Binding Category}" Value="軍艦・細巻">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Grid>
                                                        <Ellipse Width="100" Height="36" Fill="#E2E8F0" Stroke="#CBD5E1" StrokeThickness="2" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                                        <!-- Nori Wrap (Black Wall) -->
                                                        <Border Width="65" Height="28" Background="#111827" CornerRadius="14,14,8,8" VerticalAlignment="Bottom" Margin="0,0,0,12">
                                                            <Grid>
                                                                <!-- Rice base inside -->
                                                                <Border Width="57" Height="10" Background="White" CornerRadius="5" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                                            </Grid>
                                                        </Border>
                                                        
                                                        <!-- Fillings (Conditional on name) -->
                                                        <!-- 1. Ikura (Red Beads) -->
                                                        <UniformGrid Columns="4" Rows="3" Width="48" Height="14" VerticalAlignment="Bottom" Margin="0,0,0,26" x:Name="IkuraGrid" Visibility="Collapsed">
                                                            <Ellipse Width="8" Height="8" Fill="#EF4444"/>
                                                            <Ellipse Width="8" Height="8" Fill="#F97316"/>
                                                            <Ellipse Width="8" Height="8" Fill="#EF4444"/>
                                                            <Ellipse Width="8" Height="8" Fill="#EF4444"/>
                                                            <Ellipse Width="8" Height="8" Fill="#F97316"/>
                                                            <Ellipse Width="8" Height="8" Fill="#EF4444"/>
                                                            <Ellipse Width="8" Height="8" Fill="#F97316"/>
                                                            <Ellipse Width="8" Height="8" Fill="#EF4444"/>
                                                        </UniformGrid>
                                                        <!-- 2. Corn Mayo (Yellow) -->
                                                        <Border x:Name="CornFill" Width="52" Height="14" Background="#FBBF24" CornerRadius="7" VerticalAlignment="Bottom" Margin="0,0,0,26" Visibility="Collapsed">
                                                            <TextBlock Text="🌽" FontSize="10" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <!-- 3. Salad (White/Pink Mix) -->
                                                        <Border x:Name="SaladFill" Width="52" Height="14" Background="#F1F5F9" CornerRadius="7" VerticalAlignment="Bottom" Margin="0,0,0,26" Visibility="Collapsed">
                                                            <Border Width="16" Height="8" Background="#FDA4AF" CornerRadius="4" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <!-- 4. Default Negitoro (Pink paste) -->
                                                        <Border x:Name="TunaFill" Width="52" Height="14" Background="#FDA4AF" CornerRadius="7" VerticalAlignment="Bottom" Margin="0,0,0,26">
                                                            <Ellipse Width="8" Height="8" Fill="#22C55E" Margin="10,0,0,0" HorizontalAlignment="Left"/>
                                                        </Border>
                                                    </Grid>
                                                    <ControlTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding Name}" Value="いくら軍艦">
                                                            <Setter TargetName="IkuraGrid" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="TunaFill" Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Name}" Value="コーン軍艦">
                                                            <Setter TargetName="CornFill" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="TunaFill" Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Name}" Value="サラダ軍艦">
                                                            <Setter TargetName="SaladFill" Property="Visibility" Value="Visible"/>
                                                            <Setter TargetName="TunaFill" Property="Visibility" Value="Collapsed"/>
                                                        </DataTrigger>
                                                    </ControlTemplate.Triggers>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- Ramen -->
                                    <DataTrigger Binding="{Binding Name}" Value="醤油らーめん">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Grid>
                                                        <!-- Ramen Bowl -->
                                                        <Path Data="M 15,30 L 85,30 Q 80,65 50,65 Q 20,65 15,30 Z" Fill="#EF4444" Stroke="#1E293B" StrokeThickness="2" VerticalAlignment="Bottom" Margin="0,0,0,10" Width="90" Height="50"/>
                                                        <Ellipse Width="82" Height="14" Fill="#F59E0B" VerticalAlignment="Bottom" Margin="0,0,0,44"/>
                                                        <!-- Nori sheet -->
                                                        <Rectangle Width="20" Height="25" Fill="#111827" RadiusX="2" RadiusY="2" VerticalAlignment="Bottom" Margin="15,0,0,32" HorizontalAlignment="Left"/>
                                                        <!-- Egg -->
                                                        <Ellipse Width="16" Height="12" Fill="White" VerticalAlignment="Bottom" Margin="0,0,45,36" HorizontalAlignment="Right"/>
                                                        <Ellipse Width="8" Height="6" Fill="#F59E0B" VerticalAlignment="Bottom" Margin="0,0,49,39" HorizontalAlignment="Right"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- Chawanmushi -->
                                    <DataTrigger Binding="{Binding Name}" Value="特製茶碗蒸し">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Grid>
                                                        <!-- Steaming Cup -->
                                                        <Border Width="50" Height="50" Background="#E2E8F0" BorderBrush="#94A3B8" BorderThickness="2" CornerRadius="0,0,15,15" VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                                                        <Border Width="56" Height="8" Background="#FDA4AF" CornerRadius="4" VerticalAlignment="Bottom" Margin="0,0,0,56"/>
                                                        <!-- Steam lines -->
                                                        <Path Data="M 20,15 Q 15,5 20,0" Stroke="#CBD5E1" StrokeThickness="2" VerticalAlignment="Top" Margin="25,8,0,0" HorizontalAlignment="Left"/>
                                                        <Path Data="M 35,15 Q 30,5 35,0" Stroke="#CBD5E1" StrokeThickness="2" VerticalAlignment="Top" Margin="35,5,0,0" HorizontalAlignment="Left"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- Beer -->
                                    <DataTrigger Binding="{Binding Name}" Value="生ビール">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Grid>
                                                        <!-- Glass -->
                                                        <Path Data="M 30,10 L 70,10 L 65,60 L 35,60 Z" Fill="#F59E0B" Stroke="#F8FAFC" StrokeThickness="2" VerticalAlignment="Bottom" Margin="0,0,0,8" Width="60" Height="55"/>
                                                        <!-- Foam -->
                                                        <Border Width="46" Height="16" Background="White" CornerRadius="8" VerticalAlignment="Bottom" Margin="0,0,0,56"/>
                                                        <!-- Handle -->
                                                        <Path Data="M 65,20 L 78,20 L 78,45 L 63,45" Stroke="#F8FAFC" StrokeThickness="4" Fill="Transparent" VerticalAlignment="Bottom" Margin="0,0,0,16"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- Dessert/Pudding -->
                                    <DataTrigger Binding="{Binding Name}" Value="ぷるぷるプリン">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Grid>
                                                        <!-- Plate -->
                                                        <Ellipse Width="90" Height="24" Fill="#F1F5F9" Stroke="#CBD5E1" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                                                        <!-- Custard body -->
                                                        <Path Data="M 28,25 L 72,25 L 78,50 L 22,50 Z" Fill="#FDE047" VerticalAlignment="Bottom" Margin="0,0,0,12" Width="80" Height="30"/>
                                                        <!-- Caramel top -->
                                                        <Border Width="44" Height="8" Background="#78350F" CornerRadius="4" VerticalAlignment="Bottom" Margin="0,0,0,36"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- Whelk (つぶ貝) -->
                                    <DataTrigger Binding="{Binding Name}" Value="つぶ貝">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Grid>
                                                        <Ellipse Width="100" Height="36" Fill="#E2E8F0" Stroke="#CBD5E1" StrokeThickness="2" VerticalAlignment="Bottom" Margin="0,0,0,4"/>
                                                        <Border Width="50" Height="20" Background="White" CornerRadius="10" VerticalAlignment="Bottom" Margin="0,0,0,14"/>
                                                        <!-- Creamy white/beige color for Whelk -->
                                                        <Border Width="68" Height="14" Background="#FFFDF0" BorderBrush="#E2D6B5" BorderThickness="1" CornerRadius="6" VerticalAlignment="Bottom" Margin="0,0,0,22">
                                                            <Grid>
                                                                <Path Data="M 15,2 Q 34,10 53,2 M 20,8 Q 34,12 48,8" Stroke="#D2C29D" StrokeThickness="1.5"/>
                                                            </Grid>
                                                        </Border>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- Karaage (旨だれからあげ) -->
                                    <DataTrigger Binding="{Binding Name}" Value="旨だれからあげ">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Grid>
                                                        <Ellipse Width="90" Height="28" Fill="#F1F5F9" Stroke="#CBD5E1" StrokeThickness="1.5" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                                                        <!-- Karaage chunks (Golden brown blobs) -->
                                                        <Ellipse Width="24" Height="22" Fill="#78350F" VerticalAlignment="Bottom" Margin="0,0,30,12" HorizontalAlignment="Center"/>
                                                        <Ellipse Width="26" Height="24" Fill="#92400E" VerticalAlignment="Bottom" Margin="25,0,0,12" HorizontalAlignment="Center"/>
                                                        <Ellipse Width="22" Height="20" Fill="#B45309" VerticalAlignment="Bottom" Margin="0,0,0,22" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- French Fries (フライドポテト) -->
                                    <DataTrigger Binding="{Binding Name}" Value="フライドポテト">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Grid>
                                                        <Path Data="M 35,45 L 65,45 L 72,15 L 28,15 Z" Fill="#EF4444" VerticalAlignment="Bottom" Margin="0,0,0,8"/>
                                                        <Rectangle Width="6" Height="30" Fill="#FBBF24" RadiusX="1" RadiusY="1" VerticalAlignment="Bottom" Margin="0,0,20,20" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                            <Rectangle.RenderTransform>
                                                                <RotateTransform Angle="-15"/>
                                                            </Rectangle.RenderTransform>
                                                        </Rectangle>
                                                        <Rectangle Width="6" Height="34" Fill="#F59E0B" RadiusX="1" RadiusY="1" VerticalAlignment="Bottom" Margin="0,0,5,20" HorizontalAlignment="Center"/>
                                                        <Rectangle Width="6" Height="28" Fill="#FBBF24" RadiusX="1" RadiusY="1" VerticalAlignment="Bottom" Margin="15,0,0,20" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                                                            <Rectangle.RenderTransform>
                                                                <RotateTransform Angle="10"/>
                                                            </Rectangle.RenderTransform>
                                                        </Rectangle>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- Miso Soup (味噌汁) -->
                                    <DataTrigger Binding="{Binding Name}" Value="味噌汁">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Grid>
                                                        <Path Data="M 25,30 L 75,30 Q 70,60 50,60 Q 30,60 25,30 Z" Fill="#111827" Stroke="#EF4444" StrokeThickness="2" VerticalAlignment="Bottom" Margin="0,0,0,10" Width="80" Height="45"/>
                                                        <Ellipse Width="66" Height="10" Fill="#B45309" VerticalAlignment="Bottom" Margin="0,0,0,40"/>
                                                        <Ellipse Width="4" Height="3" Fill="#22C55E" VerticalAlignment="Bottom" Margin="0,0,20,44" HorizontalAlignment="Center"/>
                                                        <Ellipse Width="4" Height="3" Fill="#22C55E" VerticalAlignment="Bottom" Margin="15,0,0,42" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- Mille Crepe (ミルククレープ) -->
                                    <DataTrigger Binding="{Binding Name}" Value="ミルククレープ">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Grid>
                                                        <Ellipse Width="90" Height="24" Fill="#F1F5F9" Stroke="#CBD5E1" VerticalAlignment="Bottom" Margin="0,0,0,6"/>
                                                        <Path Data="M 25,44 L 75,44 L 65,16 Z" Fill="#FEF08A" Stroke="#EAB308" StrokeThickness="1" VerticalAlignment="Bottom" Margin="0,0,0,12"/>
                                                        <Line X1="32" Y1="36" X2="70" Y2="36" Stroke="White" StrokeThickness="1.5" VerticalAlignment="Bottom" Margin="0,0,0,20"/>
                                                        <Line X1="40" Y1="28" X2="66" Y2="28" Stroke="White" StrokeThickness="1.5" VerticalAlignment="Bottom" Margin="0,0,0,28"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- Vanilla Ice Cream (バニラアイス) -->
                                    <DataTrigger Binding="{Binding Name}" Value="バニラアイス">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Grid>
                                                        <Path Data="M 32,25 L 68,25 L 60,50 L 40,50 Z" Fill="#E2E8F0" Stroke="#94A3B8" StrokeThickness="1" VerticalAlignment="Bottom" Margin="0,0,0,8" Width="50" Height="30"/>
                                                        <Ellipse Width="44" Height="40" Fill="#F8FAFC" VerticalAlignment="Bottom" Margin="0,0,0,24">
                                                            <Ellipse.Effect>
                                                                <DropShadowEffect BlurRadius="4" ShadowDepth="1" Opacity="0.15"/>
                                                            </Ellipse.Effect>
                                                        </Ellipse>
                                                        <Path Data="M 50,45 Q 60,55 52,60 Q 45,52 50,45" Fill="#22C55E" VerticalAlignment="Bottom" Margin="5,0,0,40" HorizontalAlignment="Center"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                    <!-- Orange Juice (オレンジジュース) -->
                                    <DataTrigger Binding="{Binding Name}" Value="オレンジジュース">
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ContentControl">
                                                    <Grid>
                                                        <Path Data="M 35,12 L 65,12 L 60,52 L 40,52 Z" Fill="Transparent" Stroke="#F8FAFC" StrokeThickness="2" VerticalAlignment="Bottom" Margin="0,0,0,8" Width="50" Height="50"/>
                                                        <Path Data="M 37,22 L 63,22 L 60,51 L 40,51 Z" Fill="#F97316" VerticalAlignment="Bottom" Margin="0,0,0,9" Width="46" Height="38"/>
                                                        <Line X1="32" Y1="8" X2="48" Y2="44" Stroke="#EF4444" StrokeThickness="3" VerticalAlignment="Bottom" Margin="0,0,0,16"/>
                                                    </Grid>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ContentControl.Style>
                    </ContentControl>

                    <!-- Text details -->
                    <StackPanel Grid.Row="2" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="15" Foreground="White" TextAlignment="Center" TextWrapping="Wrap"/>
                        <TextBlock Text="{Binding NameEn}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" TextAlignment="Center" Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Bottom Price and Order Button -->
                    <Grid Grid.Row="3" Margin="0,4,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding FormattedPrice}" Foreground="{StaticResource AccentGoldBrush}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="注文" Style="{StaticResource KuraButtonStyle}" Padding="10,4" FontSize="13" 
                                Command="{Binding DataContext.SelectSushiCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}"/>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <!-- Main Shell -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="65"/> <!-- Header -->
            <RowDefinition Height="*"/>  <!-- Main Area -->
            <RowDefinition Height="85"/> <!-- Bottom Bar -->
        </Grid.RowDefinitions>

        <!-- 1. Header Bar -->
        <Border Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid Margin="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Brand logo & Table No -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource AccentRedBrush}" CornerRadius="6" Width="36" Height="36" Margin="0,0,12,0">
                        <TextBlock Text="くら" Foreground="White" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="くら寿司風 テーブルオーダー" Foreground="White" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Border Background="{StaticResource CardBrush}" CornerRadius="15" Margin="20,0,0,0" Padding="14,6" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <TextBlock Text="{Binding TableNumber}" Foreground="{StaticResource AccentGoldBrush}" FontWeight="Bold" FontSize="14"/>
                    </Border>

                    <!-- NEW: Bikkura Pon Toggle Button -->
                    <ToggleButton IsChecked="{Binding IsBikkuraPonEnabled}" Margin="20,0,0,0" Height="32" Width="170" VerticalAlignment="Center">
                        <ToggleButton.Style>
                            <Style TargetType="ToggleButton">
                                <Setter Property="Background" Value="#334155"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                                <Setter Property="FontSize" Value="12"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border CornerRadius="16" Background="{TemplateBinding Background}" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                                                <Grid>
                                                    <TextBlock x:Name="Txt" Text="びっくらポン：不参加 ❌" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{TemplateBinding Foreground}"/>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter Property="Background" Value="{StaticResource KuraGreenDarkBrush}"/>
                                                    <Setter Property="Foreground" Value="White"/>
                                                    <Setter TargetName="Txt" Property="Text" Value="びっくらポン：参加中 🎯"/>
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Cursor" Value="Hand"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ToggleButton.Style>
                    </ToggleButton>
                </StackPanel>

                <!-- SQL Connection Badge Indicator -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Ellipse Width="10" Height="10" Margin="0,0,8,0">
                        <Ellipse.Style>
                            <Style TargetType="Ellipse">
                                <Setter Property="Fill" Value="{StaticResource AccentRedBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSqlAvailable}" Value="True">
                                        <Setter Property="Fill" Value="{StaticResource KuraGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Ellipse.Style>
                    </Ellipse>
                    
                    <TextBlock FontSize="13" VerticalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource BaseTextStyle}">
                                <Setter Property="Text" Value="デモモード (DBオフライン)"/>
                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSqlAvailable}" Value="True">
                                        <Setter Property="Text" Value="データベース接続済 (LocalDB)"/>
                                        <Setter Property="Foreground" Value="{StaticResource KuraGreenBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 2. Main Area (Split into Left Category tabs / Right Delivery Status list) -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/> <!-- Sushi Grid menu -->
                <ColumnDefinition Width="300"/> <!-- Order Status list -->
            </Grid.ColumnDefinitions>

            <!-- Menu grid with Vertical Categories Tab Control -->
            <TabControl Style="{StaticResource VerticalTabControlStyle}" 
                        ItemsSource="{Binding Categories}"
                        SelectedItem="{Binding SelectedCategory}">
                <TabControl.ContentTemplate>
                    <DataTemplate>
                        <!-- Grid list of items -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding DataContext.FilteredSushiItems, RelativeSource={RelativeSource AncestorType=Window}}"
                                          ItemTemplate="{StaticResource SushiItemTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </DataTemplate>
                </TabControl.ContentTemplate>
            </TabControl>

            <!-- Right Sidebar: Live delivery status list -->
            <Border Grid.Column="1" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0" Padding="12">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="注文履歴・お届け状況" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0,0,0,10"/>

                    <ListBox Grid.Row="1" ItemsSource="{Binding OrderedHistory}" Style="{StaticResource ModernListBoxStyle}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="4,2">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Sushi Name & Quantity -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding Item.Name}" Foreground="White" FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text=" x" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                        <TextBlock Text="{Binding Quantity}" Foreground="{StaticResource AccentGoldBrush}" FontWeight="Bold" FontSize="13"/>
                                        <TextBlock Text="皿" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                                    </StackPanel>

                                    <!-- Order Time -->
                                    <TextBlock Grid.Row="1" Text="{Binding FormattedOrderTime}" Foreground="{StaticResource TextMutedBrush}" FontSize="10" Margin="0,2,0,0"/>

                                    <!-- Status Badge -->
                                    <Border Grid.Column="1" Grid.RowSpan="2" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="#334155"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="注文済">
                                                        <Setter Property="Background" Value="#1E293B"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="調理中">
                                                        <Setter Property="Background" Value="#1E3A8A"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="お届け済">
                                                        <Setter Property="Background" Value="{StaticResource KuraGreenDarkBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <TextBlock Text="{Binding Status}" Foreground="White" FontSize="11" FontWeight="Bold"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <!-- 3. Bottom Control Bar -->
        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0" Padding="20,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="200"/> <!-- Total Plates & Cost -->
                    <ColumnDefinition Width="*"/>   <!-- Bikkura Pon progress -->
                    <ColumnDefinition Width="Auto"/> <!-- Buttons -->
                </Grid.ColumnDefinitions>

                <!-- Totals -->
                <StackPanel VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="お食事 合計: " Foreground="{StaticResource TextMutedBrush}" FontSize="13"/>
                        <TextBlock Text="{Binding GrandTotal}" Foreground="{StaticResource AccentGoldBrush}" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text=" 円" Foreground="{StaticResource AccentGoldBrush}" FontSize="13" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <TextBlock Text="対象皿数: " Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                        <TextBlock Text="{Binding PlateCount}" Foreground="White" FontSize="14" FontWeight="Bold"/>
                        <TextBlock Text=" 皿" Foreground="{StaticResource TextMutedBrush}" FontSize="12"/>
                    </StackPanel>
                </StackPanel>

                <!-- Bikkura Pon status tracker -->
                <Grid Grid.Column="1" Margin="40,0" VerticalAlignment="Center">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,6">
                        <TextBlock Text="びっくらポン！ゲームまであと " Foreground="White" FontSize="13"/>
                        <TextBlock Text="{Binding BikkuraPonMilestone}" Foreground="{StaticResource AccentGoldBrush}" FontSize="15" FontWeight="Bold"/>
                        <TextBlock Text=" 皿 (5皿ごと)" Foreground="White" FontSize="13"/>
                    </StackPanel>

                    <!-- Custom styled progress bar (0 to 5) -->
                    <Grid Grid.Row="1" Height="14" Width="400" HorizontalAlignment="Center">
                        <!-- BG -->
                        <Border CornerRadius="7" Background="#1E293B" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1"/>
                        <!-- Filled progress bar indicator -->
                        <ProgressBar Value="{Binding BikkuraPonProgress, Mode=OneWay}" Minimum="0" Maximum="5" Height="12" BorderThickness="0" Background="Transparent">
                            <ProgressBar.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#10B981" Offset="0"/>
                                    <GradientStop Color="#059669" Offset="1"/>
                                </LinearGradientBrush>
                            </ProgressBar.Foreground>
                        </ProgressBar>
                    </Grid>
                </Grid>

                <!-- Service Actions -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="呼出" Style="{StaticResource GoldButtonStyle}" Padding="20,12" Margin="0,0,12,0" Command="{Binding CallStaffCommand}"/>
                    <Button Content="会計" Style="{StaticResource KuraButtonStyle}" Padding="30,12" Command="{Binding ShowCheckoutCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== MODALS / OVERLAYS ==================== -->

        <!-- A. Order Confirmation Dialog Overlay -->
        <Grid Grid.RowSpan="3" Background="#A0000000" Visibility="{Binding IsOrderConfirmVisible, Converter={StaticResource BoolToVisibleConverter}}" Panel.ZIndex="10">
            <Border Background="{StaticResource PanelBrush}" Style="{StaticResource CardStyle}" Width="480" Height="320" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Title -->
                    <TextBlock Text="注文の確認" Foreground="{StaticResource AccentGoldBrush}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>

                    <!-- Content -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="{Binding SelectedSushi.Name}" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedSushi.FormattedPrice}" Foreground="{StaticResource TextMutedBrush}" FontSize="16" HorizontalAlignment="Center" Margin="0,4,0,16"/>

                        <!-- Quantity Selector -->
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                            <Button Content="－" Style="{StaticResource RedButtonStyle}" Width="44" Height="44" FontSize="20" Padding="0" Command="{Binding DecrementQuantityCommand}"/>
                            <Border Width="60" Background="#1E293B" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Margin="10,0" CornerRadius="4">
                                <TextBlock Text="{Binding OrderQuantity}" Foreground="White" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <Button Content="＋" Style="{StaticResource KuraButtonStyle}" Width="44" Height="44" FontSize="20" Padding="0" Command="{Binding IncrementQuantityCommand}"/>
                        </StackPanel>
                    </StackPanel>

                    <!-- Footer Action buttons -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="キャンセル" Style="{StaticResource RedButtonStyle}" Margin="0,0,10,0" Command="{Binding CancelOrderConfirmCommand}"/>
                        <Button Grid.Column="1" Content="注文を確定" Style="{StaticResource KuraButtonStyle}" Margin="10,0,0,0" Command="{Binding ConfirmOrderCommand}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- B. Staff Call Overlay -->
        <Grid Grid.RowSpan="3" Background="#A0000000" Visibility="{Binding IsStaffCallVisible, Converter={StaticResource BoolToVisibleConverter}}" Panel.ZIndex="10">
            <Border Background="{StaticResource PanelBrush}" Style="{StaticResource CardStyle}" Width="400" Height="220" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="🔔 スタッフ呼出" Foreground="{StaticResource AccentGoldBrush}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="1" Text="スタッフを呼び出しています。&#x0a;そのままお待ちください。" Foreground="White" FontSize="16" TextAlignment="Center" VerticalAlignment="Center" LineHeight="24"/>

                    <Button Grid.Row="2" Content="閉じる" Style="{StaticResource KuraButtonStyle}" Width="150" HorizontalAlignment="Center" Command="{Binding CloseStaffCallCommand}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- C. Checkout Billing Summary Overlay -->
        <Grid Grid.RowSpan="3" Background="#A0000000" Visibility="{Binding IsCheckoutVisible, Converter={StaticResource BoolToVisibleConverter}}" Panel.ZIndex="10">
            <Border Background="{StaticResource PanelBrush}" Style="{StaticResource CardStyle}" Width="520" Height="450" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="💳 お会計の確認" Foreground="{StaticResource AccentGoldBrush}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>

                    <!-- Bill Breakdown -->
                    <Border Grid.Row="1" Background="#1E293B" CornerRadius="8" Padding="16" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Text="伝票明細" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                            <Grid Grid.Row="1" Margin="0,4">
                                <TextBlock Text="対象寿司皿数" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding PlateCount, StringFormat={}{0} 皿}" Foreground="White" HorizontalAlignment="Right" FontWeight="Bold"/>
                            </Grid>
                            
                            <Border Grid.Row="2" BorderThickness="0,1,0,0" BorderBrush="{StaticResource BorderBrush}" Margin="0,8"/>

                            <ScrollViewer Grid.Row="3" VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding OrderedHistory}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="60"/>
                                                    <ColumnDefinition Width="80"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Item.Name}" Foreground="White"/>
                                                <TextBlock Grid.Column="1" Text="{Binding Quantity, StringFormat={}x{0}}" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                                <TextBlock Grid.Column="2" Text="{Binding FormattedTotalPrice}" Foreground="White" HorizontalAlignment="Right"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- Grand Total -->
                    <StackPanel Grid.Row="2" Margin="0,16" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Text="合計金額: " Foreground="White" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding GrandTotal}" Foreground="{StaticResource AccentGoldBrush}" FontSize="24" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text=" 円 (税込)" Foreground="White" FontSize="14" VerticalAlignment="Bottom" Margin="4,0,0,3"/>
                    </StackPanel>

                    <!-- Checkout Actions -->
                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Content="戻る" Style="{StaticResource RedButtonStyle}" Margin="0,0,10,0" Command="{Binding CloseCheckoutCommand}"/>
                        <Button Grid.Column="1" Content="レジへ進む" Style="{StaticResource KuraButtonStyle}" Margin="10,0,0,0" Command="{Binding ConfirmCheckoutCommand}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- D. Checkout Complete Overlay -->
        <Grid Grid.RowSpan="3" Background="#A0000000" Visibility="{Binding IsCheckoutCompleteVisible, Converter={StaticResource BoolToVisibleConverter}}" Panel.ZIndex="10">
            <Border Background="{StaticResource PanelBrush}" Style="{StaticResource CardStyle}" Width="450" Height="260" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="🎉 お会計手続き完了" Foreground="{StaticResource KuraGreenBrush}" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center"/>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center">
                        <TextBlock Text="伝票を発行しました。" Foreground="White" FontSize="16" HorizontalAlignment="Center"/>
                        <TextBlock Text="お出口付近のセルフレジにて&#x0a;お会計をお願いいたします。" Foreground="{StaticResource TextMutedBrush}" FontSize="14" HorizontalAlignment="Center" TextAlignment="Center" Margin="0,10,0,0" LineHeight="20"/>
                    </StackPanel>

                    <Button Grid.Row="2" Content="テーブルをクリアする" Style="{StaticResource KuraButtonStyle}" Width="200" HorizontalAlignment="Center" Click="ClearSession_Click"/>
                </Grid>
            </Border>
        </Grid>

        <!-- E. Database Connection Warning Dialogue -->
        <Grid Grid.RowSpan="3" Background="#A0000000" Visibility="{Binding IsDatabaseWarningVisible, Converter={StaticResource BoolToVisibleConverter}}" Panel.ZIndex="10">
            <Border Background="{StaticResource PanelBrush}" Style="{StaticResource CardStyle}" Width="480" Height="260" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Margin="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="⚠️ SQL Server 接続警告" Foreground="{StaticResource AccentGoldBrush}" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center"/>

                    <TextBlock Grid.Row="1" Text="{Binding DatabaseWarningMessage}" Foreground="White" FontSize="14" TextAlignment="Center" VerticalAlignment="Center" LineHeight="22"/>

                    <Button Grid.Row="2" Content="デモモードで続行" Style="{StaticResource KuraButtonStyle}" Width="180" HorizontalAlignment="Center" Command="{Binding CloseDatabaseWarningCommand}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- F. NEW: Delivery Arrival Notification Banner Overlay -->
        <Grid Grid.RowSpan="3" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,30,0,0" Panel.ZIndex="20"
              Visibility="{Binding IsDeliveryNotificationVisible, Converter={StaticResource BoolToVisibleConverter}}">
            <Border BorderBrush="{StaticResource KuraGreenBrush}" BorderThickness="2" CornerRadius="30" Background="#F00F172A" Height="60" Width="480">
                <Border.Effect>
                    <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="4" Opacity="0.5"/>
                </Border.Effect>
                <Grid Margin="20,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Text="🍣" FontSize="26" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="【まもなく到着】" Foreground="{StaticResource KuraGreenBrush}" FontWeight="Bold" FontSize="15" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ArrivingSushiName}" Foreground="White" FontWeight="Bold" FontSize="16" VerticalAlignment="Center" Margin="5,0,0,0"/>
                        <TextBlock Text=" x " Foreground="{StaticResource TextMutedBrush}" FontSize="14" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding ArrivingSushiQuantity}" Foreground="{StaticResource AccentGoldBrush}" FontWeight="Bold" FontSize="16" VerticalAlignment="Center"/>
                        <TextBlock Text="皿" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <TextBlock Grid.Column="2" Text="レーンを通って届きます！" Foreground="{StaticResource TextMutedBrush}" FontSize="12" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
