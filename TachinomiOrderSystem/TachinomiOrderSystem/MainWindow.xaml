<Window x:Class="TachinomiOrderSystem.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TachinomiOrderSystem"
        mc:Ignorable="d"
        Title="立ち飲みオーダーシステム (TachinomiOrderSystem)" 
        Height="680" Width="1000"
        Background="#121212"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Custom Vector Drawings for Items -->
        <Style x:Key="ItemArtStyle" TargetType="ContentControl">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContentControl">
                        <Grid Width="120" Height="100">
                            <!-- Fallback default drawing -->
                            <Ellipse Width="60" Height="60" Fill="#374151" Stroke="#4B5563" StrokeThickness="2" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <!-- Art for Draft Beer -->
                <DataTrigger Binding="{Binding Name}" Value="生ビール">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ContentControl">
                                <Grid Width="120" Height="100" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <!-- Beer Glass Base Shadow -->
                                    <Ellipse Width="70" Height="20" Fill="#050505" Opacity="0.5" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    
                                    <!-- Glass Handle (Left side) -->
                                    <Path Data="M 40,35 L 25,35 A 15,15 0 0,0 25,65 L 40,65" Stroke="#E2E8F0" StrokeThickness="5" Fill="Transparent" HorizontalAlignment="Left" Margin="20,0,0,0"/>
                                    
                                    <!-- Beer Glass & Liquid -->
                                    <Path Data="M 40,25 L 80,25 L 75,75 A 5,5 0 0,1 70,80 L 50,80 A 5,5 0 0,1 45,75 Z" Fill="#D97706" Stroke="#F1F5F9" StrokeThickness="3.5" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    
                                    <!-- Beer Fluid Highlights -->
                                    <Path Data="M 48,32 L 72,32 L 68,72 L 52,72 Z" Fill="#F59E0B" Opacity="0.85" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    
                                    <!-- Bubbles inside Beer -->
                                    <Ellipse Width="4" Height="4" Fill="#FFE0B2" Margin="52,45,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                                    <Ellipse Width="3" Height="3" Fill="#FFE0B2" Margin="66,55,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>
                                    <Ellipse Width="4" Height="4" Fill="#FFE0B2" Margin="58,62,0,0" VerticalAlignment="Top" HorizontalAlignment="Left"/>

                                    <!-- Foam Header (Thick creamy top) -->
                                    <Border Width="50" Height="22" Background="#FFFFFF" CornerRadius="11" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,15,0,0">
                                        <Border.Effect>
                                            <BlurEffect Radius="1.5"/>
                                        </Border.Effect>
                                    </Border>
                                    <Ellipse Width="25" Height="18" Fill="#FFFFFF" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="-20,13,0,0"/>
                                    <Ellipse Width="25" Height="18" Fill="#FFFFFF" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="20,13,0,0"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
                <!-- Art for Edamame -->
                <DataTrigger Binding="{Binding Name}" Value="枝豆">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ContentControl">
                                <Grid Width="120" Height="100" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <!-- Bowl Shadow -->
                                    <Ellipse Width="80" Height="15" Fill="#050505" Opacity="0.5" VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10"/>
                                    
                                    <!-- Red Lacquer Bowl -->
                                    <Path Data="M 20,45 C 20,80 100,80 100,45 Z" Fill="#991B1B" Stroke="#1E293B" StrokeThickness="2" HorizontalAlignment="Center"/>
                                    <Path Data="M 20,45 Q 60,53 100,45" Fill="#7F1D1D" Stroke="#1E293B" StrokeThickness="1"/>

                                    <!-- Edamame Pod 1 -->
                                    <Path Data="M 35,32 Q 55,25 75,40 Q 55,50 35,32" Fill="#22C55E" Stroke="#166534" StrokeThickness="1.5"/>
                                    <!-- Beans inside pod 1 -->
                                    <Ellipse Width="8" Height="8" Fill="#4ADE80" Margin="42,32,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                    <Ellipse Width="8" Height="8" Fill="#4ADE80" Margin="54,34,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>
                                    <Ellipse Width="8" Height="8" Fill="#4ADE80" Margin="64,36,0,0" HorizontalAlignment="Left" VerticalAlignment="Top"/>

                                    <!-- Edamame Pod 2 (Overlayed) -->
                                    <Path Data="M 50,22 Q 70,25 85,15 Q 75,40 50,22" Fill="#15803D" Stroke="#14532D" StrokeThickness="1.5"/>
                                    
                                    <!-- Edamame Pod 3 (Left side) -->
                                    <Path Data="M 25,48 Q 45,55 65,48 Q 45,40 25,48" Fill="#16A34A" Stroke="#15803D" StrokeThickness="1.5"/>
                                </Grid>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Base Button Template with rounded corners and nice feedback -->
        <Style x:Key="ModernButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#1F2937"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#374151"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#111827"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AccentButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#F59E0B"/>
            <Setter Property="Foreground" Value="#121212"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#FBBF24"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#D97706"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource ModernButtonStyle}">
            <Setter Property="Background" Value="#EF4444"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#F87171"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#DC2626"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <!-- Background decorative warm gradient circles -->
        <Canvas IsHitTestVisible="False" Opacity="0.15">
            <Ellipse Width="400" Height="400" Fill="#F59E0B" Canvas.Left="-100" Canvas.Top="-100">
                <Ellipse.Effect>
                    <BlurEffect Radius="100"/>
                </Ellipse.Effect>
            </Ellipse>
            <Ellipse Width="300" Height="300" Fill="#10B981" Canvas.Right="-50" Canvas.Bottom="-50">
                <Ellipse.Effect>
                    <BlurEffect Radius="80"/>
                </Ellipse.Effect>
            </Ellipse>
        </Canvas>

        <!-- Main Layout Split -->
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/> <!-- Title Bar -->
                <RowDefinition Height="*"/>    <!-- Content Area -->
            </Grid.RowDefinitions>

            <!-- Header -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="🍺 立ち飲み処『達人』" FontSize="26" FontWeight="Bold" Foreground="White" FontFamily="Segoe UI, Microsoft YaHei"/>
                    <Border CornerRadius="12" Background="#1E2937" Margin="15,0,0,0" Padding="10,4" VerticalAlignment="Center">
                        <TextBlock Text="立ち飲み基本学習システム" FontSize="12" Foreground="#F59E0B" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
                <!-- Offline status or indicator & History Button -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Button Content="📋 会計履歴を見る" Style="{StaticResource ModernButtonStyle}" Height="34" Margin="0,0,15,0" Padding="12,0" VerticalContentAlignment="Center" Command="{Binding ToggleHistoryCommand}"/>
                    <Border CornerRadius="12" Padding="12,5" VerticalAlignment="Center">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#7F1D1D"/> <!-- Default offline red -->
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSqlAvailable}" Value="True">
                                    <Setter Property="Background" Value="#065F46"/> <!-- Online green -->
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center" Margin="0,0,8,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#EF4444"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSqlAvailable}" Value="True">
                                            <Setter Property="Fill" Value="#10B981"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock FontSize="12" Foreground="White" FontWeight="Bold">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="DB接続エラー (オフライン)"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSqlAvailable}" Value="True">
                                            <Setter Property="Text" Value="LocalDB 接続中"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Border>
            </StackPanel>
            </Grid>

            <!-- Columns -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380"/> <!-- Left Sidebar: Orders -->
                    <ColumnDefinition Width="20"/>  <!-- Spacer -->
                    <ColumnDefinition Width="*"/>   <!-- Right Pane: Menu Grid -->
                </Grid.ColumnDefinitions>

                <!-- Left Sidebar: Order History Cart -->
                <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="12" BorderBrush="#2D2D2D" BorderThickness="1">
                    <Grid Margin="15">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/> <!-- Cart Header -->
                            <RowDefinition Height="*"/>    <!-- Order History List -->
                            <RowDefinition Height="Auto"/> <!-- Footer Details -->
                            <RowDefinition Height="Auto"/> <!-- Action Buttons -->
                        </Grid.RowDefinitions>

                        <!-- Header -->
                        <TextBlock Grid.Row="0" Text="ご注文明細" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,10"/>

                        <!-- List of Placed Orders -->
                        <ListBox Grid.Row="1" ItemsSource="{Binding OrderedHistory}" Background="Transparent" BorderThickness="0" Margin="0,0,0,10" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Background" Value="Transparent"/>
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                    <Setter Property="Margin" Value="0,0,0,8"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border Background="#262626" CornerRadius="8" Padding="12,10" BorderBrush="#3A3A3A" BorderThickness="1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto"/>
                                                            <RowDefinition Height="Auto"/>
                                                        </Grid.RowDefinitions>

                                                        <!-- Item Name -->
                                                        <TextBlock Grid.Column="0" Grid.Row="0" Text="{Binding Item.Name}" FontSize="15" FontWeight="Bold" Foreground="White"/>
                                                        
                                                        <!-- Order Time -->
                                                        <TextBlock Grid.Column="0" Grid.Row="1" Text="{Binding FormattedOrderTime}" FontSize="11" Foreground="#9CA3AF" Margin="0,4,0,0"/>

                                                        <!-- Qty & Price -->
                                                        <StackPanel Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" HorizontalAlignment="Right" VerticalAlignment="Center" Orientation="Horizontal">
                                                            <TextBlock Text="{Binding Quantity, StringFormat={}{0}つ}" FontSize="14" Foreground="#9CA3AF" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                                            <TextBlock Text="{Binding FormattedTotalPrice}" FontSize="16" FontWeight="Bold" Foreground="#F59E0B" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                        </ListBox>

                        <!-- Footer Details -->
                        <Border Grid.Row="2" BorderBrush="#2D2D2D" BorderThickness="0,1,0,0" Padding="0,15,0,15">
                            <Grid>
                                <TextBlock Text="合計金額 (税込)" FontSize="16" FontWeight="SemiBold" Foreground="#E5E7EB" VerticalAlignment="Center"/>
                                <TextBlock Text="{Binding GrandTotal, StringFormat={}{0} 円}" FontSize="24" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Checkout & Clear buttons -->
                        <Grid Grid.Row="3">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Button Content="お会計をする" Style="{StaticResource AccentButtonStyle}" Height="50" FontSize="16" Command="{Binding ShowCheckoutCommand}"/>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Right Pane: Menu Selection Grid -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="メニューを選択してください" FontSize="18" FontWeight="Bold" Foreground="White" Margin="0,0,0,15"/>

                    <!-- Grid showing items -->
                    <ItemsControl Grid.Row="1" ItemsSource="{Binding MenuItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2" Rows="1" VerticalAlignment="Top"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.SelectMenuItemCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}" CommandParameter="{Binding}" Background="#1E1E1E" BorderBrush="#2D2D2D" BorderThickness="1" Margin="10" Padding="15">
                                    <Button.Template>
                                        <ControlTemplate TargetType="Button">
                                            <Border x:Name="bgBorder" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="12" Cursor="Hand">
                                                <Grid Margin="10">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/> <!-- Art -->
                                                        <RowDefinition Height="Auto"/> <!-- Item Name -->
                                                        <RowDefinition Height="Auto"/> <!-- Price -->
                                                        <RowDefinition Height="Auto"/> <!-- Order Button Banner -->
                                                    </Grid.RowDefinitions>

                                                    <!-- Vector Art -->
                                                    <ContentControl Grid.Row="0" Content="{Binding}" Style="{StaticResource ItemArtStyle}" Height="120" HorizontalAlignment="Center" Margin="0,10,0,15"/>

                                                    <!-- Name -->
                                                    <TextBlock Grid.Row="1" Text="{Binding Name}" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,6"/>

                                                    <!-- Price -->
                                                    <TextBlock Grid.Row="2" Text="{Binding FormattedPrice}" FontSize="16" FontWeight="SemiBold" Foreground="#F59E0B" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                                                    <!-- Interactive Badge -->
                                                    <Border x:Name="badge" Grid.Row="3" Background="#2E2E2E" CornerRadius="8" Padding="15,8" HorizontalAlignment="Stretch">
                                                        <TextBlock Text="注文する" Foreground="White" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center"/>
                                                    </Border>
                                                </Grid>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="bgBorder" Property="Background" Value="#262626"/>
                                                    <Setter TargetName="bgBorder" Property="BorderBrush" Value="#4B5563"/>
                                                    <Setter TargetName="badge" Property="Background" Value="#F59E0B"/>
                                                    <Setter TargetName="badge" Property="Opacity" Value="0.9"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Button.Template>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </Grid>

        <!-- Popups and Dialogs overlay -->

        <!-- 1. Order Confirm Modal -->
        <Grid Background="#B0000000">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsOrderConfirmVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#1E1E1E" Width="420" Height="340" CornerRadius="16" BorderBrush="#2D2D2D" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Title -->
                        <RowDefinition Height="*"/>    <!-- Quantity Picker -->
                        <RowDefinition Height="Auto"/> <!-- Buttons -->
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" HorizontalAlignment="Center" Margin="0,0,0,20">
                        <TextBlock Text="ご注文の確認" FontSize="16" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedMenuItem.Name}" FontSize="24" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                        <TextBlock Text="{Binding SelectedMenuItem.FormattedPrice}" FontSize="16" Foreground="#F59E0B" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>

                    <!-- Quantity Picker -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Button Content="-" Command="{Binding DecrementQuantityCommand}" Width="50" Height="50" FontSize="20" Style="{StaticResource ModernButtonStyle}"/>
                        <TextBlock Text="{Binding OrderQuantity}" FontSize="28" FontWeight="Bold" Foreground="White" Width="80" TextAlignment="Center" VerticalAlignment="Center"/>
                        <Button Content="+" Command="{Binding IncrementQuantityCommand}" Width="50" Height="50" FontSize="20" Style="{StaticResource ModernButtonStyle}"/>
                    </StackPanel>

                    <!-- Confirmation Buttons -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="キャンセル" Style="{StaticResource ModernButtonStyle}" Height="45" Command="{Binding CancelOrderConfirmCommand}"/>
                        <Button Grid.Column="2" Content="注文を確定する" Style="{StaticResource AccentButtonStyle}" Height="45" Command="{Binding ConfirmOrderCommand}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- 2. Checkout Modal -->
        <Grid Background="#B0000000">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCheckoutVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#1E1E1E" Width="400" Height="250" CornerRadius="16" BorderBrush="#2D2D2D" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="お会計の確認" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                    
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="伝票の合計金額は以下の通りです" FontSize="14" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding GrandTotal, StringFormat={}{0} 円}" FontSize="28" FontWeight="Bold" Foreground="#F59E0B" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="戻る" Style="{StaticResource ModernButtonStyle}" Height="45" Command="{Binding CloseCheckoutCommand}"/>
                        <Button Grid.Column="2" Content="支払い完了" Style="{StaticResource AccentButtonStyle}" Height="45" Command="{Binding ConfirmCheckoutCommand}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- 3. Checkout Complete Modal -->
        <Grid Background="#B0000000">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsCheckoutCompleteVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#1E1E1E" Width="400" Height="240" CornerRadius="16" BorderBrush="#2D2D2D" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="ご来店ありがとうございました！" FontSize="22" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                        <TextBlock Text="またのご利用をお待ちしております。" FontSize="14" Foreground="#9CA3AF" HorizontalAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>

                    <Button Grid.Row="1" Content="新しいセッションを開始" Style="{StaticResource AccentButtonStyle}" Height="48" Command="{Binding ResetSessionCommand}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- 4. Database Warning Modal -->
        <Grid Background="#B0000000">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsDatabaseWarningVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#1E1E1E" Width="420" Height="280" CornerRadius="16" BorderBrush="#DC2626" BorderThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="⚠️ DB接続警告" FontSize="20" FontWeight="Bold" Foreground="#EF4444"/>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Text="{Binding DatabaseWarningMessage}" TextWrapping="Wrap" FontSize="14" Foreground="#E5E7EB" HorizontalAlignment="Center" VerticalAlignment="Center" TextAlignment="Center" LineHeight="20"/>

                    <Button Grid.Row="2" Content="確認" Style="{StaticResource ModernButtonStyle}" Height="45" Command="{Binding CloseDatabaseWarningCommand}"/>
                </Grid>
            </Border>
        </Grid>

        <!-- 5. History Modal -->
        <Grid Background="#B0000000">
            <Grid.Style>
                <Style TargetType="Grid">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding IsHistoryVisible}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Grid.Style>
            <Border Background="#1E1E1E" Width="550" Height="480" CornerRadius="16" BorderBrush="#2D2D2D" BorderThickness="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                <Grid Margin="25">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <!-- Title -->
                        <RowDefinition Height="*"/>    <!-- History List -->
                        <RowDefinition Height="Auto"/> <!-- Buttons -->
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📋 過去のお会計履歴" FontSize="20" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                    <!-- List of Checkout History -->
                    <ListBox Grid.Row="1" ItemsSource="{Binding CheckoutHistory}" Background="Transparent" BorderThickness="0" Margin="0,0,0,15" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border Background="#262626" CornerRadius="8" Padding="12" BorderBrush="#3A3A3A" BorderThickness="1">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto"/>
                                                        <RowDefinition Height="Auto"/>
                                                    </Grid.RowDefinitions>

                                                    <!-- Order details summary -->
                                                    <TextBlock Grid.Column="0" Grid.Row="0" Text="{Binding SummaryText}" FontSize="15" FontWeight="Bold" Foreground="White" TextWrapping="Wrap"/>
                                                    
                                                    <!-- Checkout Time -->
                                                    <TextBlock Grid.Column="0" Grid.Row="1" Text="{Binding FormattedOrderTime}" FontSize="11" Foreground="#9CA3AF" Margin="0,5,0,0"/>

                                                    <!-- Total Price -->
                                                    <TextBlock Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Text="{Binding FormattedTotalPrice}" FontSize="18" FontWeight="Bold" Foreground="#F59E0B" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                                </Grid>
                                            </Border>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                    </ListBox>

                    <!-- Buttons -->
                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Content="履歴をすべて削除" Style="{StaticResource DangerButtonStyle}" Height="45" Padding="20,0" Command="{Binding ClearHistoryCommand}"/>
                        <Button Grid.Column="2" Content="閉じる" Style="{StaticResource ModernButtonStyle}" Height="45" Command="{Binding ToggleHistoryCommand}"/>
                    </Grid>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
